# ============================================================
# GS ERP — Production environment template
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=CHANGE_ME_use_a_long_random_string_at_least_50_chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=gs-erp.example.com,www.gs-erp.example.com
DJANGO_TIME_ZONE=Asia/Riyadh

# MySQL
MYSQL_DB=gs_erp
MYSQL_USER=gs_erp
MYSQL_PASSWORD=CHANGE_ME_strong_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306
DB_CONN_MAX_AGE=60

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (optional — for password reset)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@gs-erp.example.com
EMAIL_HOST_PASSWORD=CHANGE_ME

# Sentry (optional — for error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# Migrations (set 0 on workers/beat, leave 1 on api)
RUN_MIGRATIONS=1
